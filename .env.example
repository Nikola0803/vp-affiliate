# Shared WordPress backend (same one every VP storefront's own site already
# uses for click-tracking). Set these as Environment Variables in the Vercel
# project (Production + Preview) dashboard — do NOT put real values in this
# file. Copy it to `.env` (gitignored) if you need real values locally for
# `vercel dev`.

WC_URL=https://db.vintagepeptides.com
WC_USER=your-wp-admin-username
WC_APP_PASSWORD=your-wp-application-password
